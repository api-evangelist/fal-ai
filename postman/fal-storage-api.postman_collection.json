  "info": {
    "_postman_id": "309f62bb-c619-4804-92f3-59d9fe8e6f9d",
    "name": "fal Storage API",
    "description": "REST endpoints for uploading binary input assets (images, audio, control maps, reference frames) to fal's CDN so they can be passed by URL when invoking model APIs. Clients first call `/storage/upload/initiate` to obtain a short-lived signed upload URL, then PUT the bytes to the returned URL. Assets are served from `https://v3.fal.media`.\n\n\nContact Support:\n Name: fal Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:00:50.000Z",
    "updatedAt": "2026-06-05T15:00:51.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-309f62bb-c619-4804-92f3-59d9fe8e6f9d"
  },
