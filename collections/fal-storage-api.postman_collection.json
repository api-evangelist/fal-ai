  "info": {
    "_postman_id": "dc742d84-18b6-453f-8015-07ba2a4ecfb1",
    "name": "fal Storage API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "REST endpoints for uploading binary input assets (images, audio, control maps, reference frames) to fal's CDN so they can be passed by URL when invoking model APIs. Clients first call `/storage/upload/initiate` to obtain a short-lived signed upload URL, then PUT the bytes to the returned URL. Assets are served from `https://v3.fal.media`.\n\n\nContact Support:\n Name: fal Support",
      "type": "text/plain"
    }
  }
