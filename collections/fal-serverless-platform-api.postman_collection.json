  "info": {
    "_postman_id": "9eed2b82-1a70-45d0-9161-ce13a35400fd",
    "name": "fal Serverless Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Platform control-plane endpoints for managing fal Serverless applications — custom GPU functions and apps deployed using `@fal.function`, `fal.App`, or bring-your-own containers. Covers app metadata, scaling, secrets, files, and execution analytics. This API backs the `fal` CLI (`fal apps list`, `fal secrets`, `fal deploy`).\n\n\nContact Support:\n Name: fal Support",
      "type": "text/plain"
    }
  }
